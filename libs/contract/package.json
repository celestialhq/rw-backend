{
  "name": "@celestialhq/backend-contract",
  "version": "2.9.20",
  "license": "AGPL-3.0-only",
  "description": "A contract library for Remnawave Backend. It can be used in backend and frontend.",
  "author": "CelestialHQ",
  "keywords": [],
  "homepage": "https://github.com/celestialhq/rw-backend",
  "bugs": {
    "url": "https://github.com/celestialhq/rw-backend/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/celestialhq/rw-backend.git",
    "directory": "libs/contract"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "build/**/*"
  ],
  "main": "build/backend/index.js",
  "browser": "build/frontend/index.js",
  "types": "build/backend/index.d.ts",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('build', { recursive: true, force: true })\"",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build:frontend": "tsc -p tsconfig.frontend.json",
    "build": "npm run clean && npm run build:backend && npm run build:frontend",
    "prepublish": "npm run build"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "public": true
}
