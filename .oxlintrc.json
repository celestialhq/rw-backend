{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "eslint", "import", "unicorn", "oxc", "node", "promise"],
  "env": { "node": true },
  "categories": { "correctness": "error" },
  "ignorePatterns": ["node_modules", "**/*.js", "**/*.d.ts"],
  "rules": {
    "no-console": "warn"
  }
}
