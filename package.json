  "type": "commonjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=development INSTANCE_TYPE=api rspack --watch --mode development",
    "dev:worker": "NODE_ENV=development INSTANCE_TYPE=processor rspack --watch --mode development",
    "dev:scheduler": "NODE_ENV=development INSTANCE_TYPE=scheduler rspack --watch --mode development",
    "build": "NODE_ENV=production rspack build",
    "build:seed": "NODE_ENV=production BUILD_SEED=1 rspack build",
    "migrate:dev": "prisma migrate dev",
    "migrate:generate": "prisma generate",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:seed": "prisma db seed",
    "migrate:seed:dev": "npm run build:seed && prisma db seed",
    "generate:openapi": "BUILD_GEN_DOC=1 rspack build --mode development && node dist/gen-doc.js",
    "new:queue": "hygen new queue",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "oxfmt --check && oxlint",
    "fix": "oxfmt && oxlint --fix"
  },
